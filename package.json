    "@tailwindcss/postcss": "^4.2.3",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.3"
  },
  "resolutions": {
    "minimatch@3.1.2": "3.1.5",
    "minimatch@9.0.5": "9.0.9"
